# Application Settings
APP_NAME=BizClone
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://bizclone_user:bizclone_pass@localhost:5432/bizclone_db
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# ElevenLabs Configuration (TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
USE_LOCAL_TTS=False

# Whisper Configuration (STT)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=en

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=plumber_knowledge

# Business Configuration
BUSINESS_NAME=QuickFix Plumbing
BUSINESS_PHONE=+1234567890
BUSINESS_EMAIL=contact@quickfixplumbing.com
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=America/New_York

# Scheduling Configuration
APPOINTMENT_DURATION_MINUTES=60
APPOINTMENT_BUFFER_MINUTES=15
MAX_DAILY_APPOINTMENTS=8

# Escalation Configuration
EMERGENCY_EMAIL=emergency@quickfixplumbing.com
EMERGENCY_PHONE=+1234567890
EMERGENCY_KEYWORDS=leak,flooding,burst,emergency,urgent,water everywhere

# File Storage
RECORDINGS_DIR=./data/recordings
TRANSCRIPTS_DIR=./data/transcripts
LOGS_DIR=./logs

# Security
SECRET_KEY=your-secret-key-change-this-in-production
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring
SENTRY_DSN=
ENABLE_METRICS=True

