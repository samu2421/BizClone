# ==============================
# Application Settings
# ==============================
APP_NAME=BizClone
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ==============================
# Server Configuration
# ==============================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==============================
# Database (PostgreSQL)
# ==============================
DATABASE_URL=postgresql://bizclone_user:bizclone_pass@localhost:5432/bizclone_db
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==============================
# Redis
# ==============================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# ==============================
# Celery
# ==============================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# ==============================
# AI Models
# ==============================

# Groq (Intent classification)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Whisper (Speech-to-text)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=en

# ==============================
# Text-to-Speech
# ==============================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
USE_LOCAL_TTS=True

# ==============================
# Vector Database
# ==============================
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=plumber_knowledge

# ==============================
# Business Settings
# ==============================
BUSINESS_NAME=QuickFix Plumbing
BUSINESS_PHONE=+1234567890
BUSINESS_EMAIL=contact@quickfixplumbing.com

BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=Europe/Berlin

# ==============================
# Scheduling
# ==============================
APPOINTMENT_DURATION_MINUTES=60
APPOINTMENT_BUFFER_MINUTES=15
MAX_DAILY_APPOINTMENTS=8

# ==============================
# Google Calendar Integration
# ==============================
# Path to service-account JSON credentials file
GOOGLE_CREDENTIALS_FILE=./credentials/google_calendar.json

# Target calendar email (events are created here)
GOOGLE_TARGET_CALENDAR=your_email@gmail.com

# ==============================
# Emergency Escalation
# ==============================
EMERGENCY_EMAIL=emergency@quickfixplumbing.com
EMERGENCY_PHONE=+1234567890
EMERGENCY_KEYWORDS=leak,flooding,burst,emergency,urgent,water everywhere

# ==============================
# File Storage
# ==============================
RECORDINGS_DIR=./data/recordings
TRANSCRIPTS_DIR=./data/transcripts
LOGS_DIR=./logs

# ==============================
# Security
# ==============================
SECRET_KEY=your-secret-key-change-this-in-production
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ==============================
# Monitoring
# ==============================
ENABLE_METRICS=True
SENTRY_DSN=

